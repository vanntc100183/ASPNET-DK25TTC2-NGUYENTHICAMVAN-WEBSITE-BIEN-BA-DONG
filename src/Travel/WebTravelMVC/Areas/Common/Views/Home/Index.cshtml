@using WebTravelMVC.Models
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Common/Views/Shared/_LayoutCommon.cshtml";
}
@{
    IEnumerable<BaiViet> listBaiVietNoiBat = ViewBag.NoiBat as IEnumerable<BaiViet>;
    IEnumerable<BaiViet> listBaiViet = ViewBag.DoanhNghiepvaLuHanh as IEnumerable<BaiViet>;
}
<!-- ***** Main Banner Area Start ***** -->
<div class="main-banner" id="top">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-6">
                <div class="left-content">
                    <div class="thumb">
                        <div class="inner-content">
                            <h4>Khám phá biển Ba Động Trà Vinh những ngày hè</h4>
                            <span>Nếu bạn muốn tìm một nơi xoa diệu cái nắng oi bức của mùa hè thì Ba Động là một lựa chọn tuyệt vời khi đến Trà Vinh</span>
                            <div class="main-border-button">
                                <a href="~/Common/BaiViet/XemChiTiet?iMaBaiViet=6">Xem Thêm</a>
                            </div>
                        </div>
                        <img style="width:730px; height:628px" src="~/Assets/images/bbd1.jpg" />
                    </div>
                </div>
            </div>
            <!-- #region Bài mới -->
            <div class="col-lg-6">
                <div class="right-content">
                    <div class="row">
                        <!-- #region Bài viết mới -->
                        @Html.Action("BaiVietMoi_Par", "Partialview")
                        <!-- #endregion -->
                    </div>
                </div>
            </div>
            <!-- #endregion -->
        </div>
    </div>
</div>
<!-- ***** Main Banner Area End ***** -->
<!-- ***** Men Area Starts ***** -->
<section class="section" id="men">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <div class="section-heading">
                    <h2>Check in công trình điện gió</h2>
                    <span>Những tua bin gió khổng lồ không ngừng làm việc như một sự kết hợp hài hòa với biển cả.</span>
                </div>
            </div>
        </div>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="men-item-carousel">
                    <div class="owl-men-item owl-carousel">
                        @foreach (var item in listBaiVietNoiBat)
                        {
                            <div class="item">
                                <div class="thumb">
                                    <img style="width:350px; height:300px" src="~/Assets/images/@item.AnhBia" alt="">
                                </div>
                                <div class="down-content">
                                    <h4>@item.TenBaiViet</h4>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ***** Men Area Ends ***** -->
<!-- ***** Women Area Starts ***** -->
