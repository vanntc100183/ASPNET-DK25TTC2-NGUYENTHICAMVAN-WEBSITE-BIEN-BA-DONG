                </div>
                <form id="subscribe" action="" method="get">
                    <div class="row">
                        <div class="col-lg-5">
                            <fieldset>
                                <input name="name" type="text" id="name" placeholder="Địa chỉ Email" required="">
                            </fieldset>
                        </div>
                        <div class="col-lg-5">
                            <fieldset>
                            </fieldset>
                        </div>
